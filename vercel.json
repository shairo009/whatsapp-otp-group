{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/api/groups/preview", "destination": "/api/groups/preview" },
    { "source": "/api/groups/submit", "destination": "/api/groups/submit" },
    { "source": "/api/groups/report", "destination": "/api/groups/report" },
    { "source": "/api/groups", "destination": "/api/groups/index" },
    { "source": "/api/admin/groups", "destination": "/api/admin/groups" },
    { "source": "/api/admin/reports", "destination": "/api/admin/reports" },
    { "source": "/api/admin/action", "destination": "/api/admin/action" },
    { "source": "/api/cron/verify", "destination": "/api/cron/verify" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/verify", "schedule": "0 3 * * *" }
  ]
}
